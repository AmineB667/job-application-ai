# DeepSeek API key — used as the fallback for visitors who don't bring their own (BYOK).
# Get one at https://platform.deepseek.com/api_keys
# IMPORTANT: in production (Render, Vercel), set this in the platform's env vars, never commit.
DEEPSEEK_API_KEY=

# Optional, defaults to https://api.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional, defaults to deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# Rate limit per IP per day for users WITHOUT their own API key.
# Defaults to 3. Increase if you want to be generous.
RATE_LIMIT_PER_DAY=3
